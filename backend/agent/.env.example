# Get from build.nvidia.com → API Keys (starts with nvapi-)
AGENT_API_KEY=nvapi-...

# Model to use — change this to swap providers without touching code
AGENT_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
AGENT_BASE_URL=https://integrate.api.nvidia.com/v1

# To use Claude instead (claude-haiku-4-5 is ~$0.001/conversation):
# AGENT_API_KEY=sk-ant-...
# AGENT_MODEL=claude-haiku-4-5-20251001
# AGENT_BASE_URL=https://api.anthropic.com/v1

# To use OpenAI GPT-4o:
# AGENT_API_KEY=sk-...
# AGENT_MODEL=gpt-4o
# AGENT_BASE_URL=https://api.openai.com/v1

# Spotify — developer.spotify.com → your app
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
# Must match an entry in your Spotify app's Redirect URIs list. Vite proxies
# /api/* to the FastAPI backend, so the OAuth callback resolves through 5173.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/api/auth/callback

# Frontend origin used for the post-OAuth redirect and cookie scope.
FRONTEND_URL=http://127.0.0.1:5173
# Set to true in production (HTTPS) to require the session cookie over TLS.
COOKIE_SECURE=false

# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

DATABASE_URL=sqlite+aiosqlite:///./agent.sqlite
