{
  "name": "music-recommender",
  "version": "3.0.0",
  "description": "AI-powered music assistant — chat to create Spotify playlists matched to your mood and weather.",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n agent,web -c blue,magenta \"npm:dev:agent\" \"npm:dev:web\"",
    "dev:agent": "cd backend && python -m uvicorn agent.main:app --reload --port 8000",
    "dev:web": "cd frontend && vite",
    "build": "cd frontend && vite build",
    "typecheck": "cd frontend && tsc --noEmit"
  },
  "dependencies": {
    "framer-motion": "^12.23.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.73",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.3",
    "vite": "^5.2.6"
  }
}
