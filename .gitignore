# ============================================================
# WARNING: local SQLite DBs may hold LIVE Spotify OAuth tokens
# (access + refresh) and active session cookies.
# Do NOT commit local DB files.
# ============================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/
*.tsbuildinfo

# Python bytecode and caches
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/

# Python virtual environments
venv/
.venv/
env/
ENV/

# Secrets / environment files
.env
.env.local
.env.development
.env.production
.env.*.local
backend/agent/.env

# SQLite DBs and scratch files
databases/
*.sqlite
backend/agent/*.sqlite
backend/agent/*.sqlite-journal
backend/agent/*.sqlite-wal
backend/agent/*.sqlite-shm
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# Legacy / local-only DB dump folder (some machines may have this open/locked)
server/

# Local AI agent notes / instructions (repo-specific)
CLAUDE.md

# Claude Code local settings (machine-specific, may contain session tokens)
.claude/settings.local.json

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/

# OS
.DS_Store
Thumbs.db
